# Project Create — Variables d'environnement
# Copier en .env et remplir les valeurs
# (ou laisser vide : ~/.bigboff/secrets.env est chargé automatiquement)

# Clé API Anthropic (obligatoire)
ANTHROPIC_API_KEY=sk-ant-...

# Modèle Claude à utiliser (optionnel)
# Défaut : claude-haiku-4-5-20251001  (rapide, économique)
# Option  : claude-sonnet-4-6          (plus puissant, plus lent)
PROJECT_CREATE_MODEL=claude-haiku-4-5-20251001
