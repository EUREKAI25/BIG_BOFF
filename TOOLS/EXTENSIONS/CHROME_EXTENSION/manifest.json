{
  "manifest_version": 3,
  "name": "Éditeur Accordéons",
  "version": "1.3.0",
  "description": "Accès rapide à l'éditeur d'accordéons imbriqués avec capture de contenu",
  "permissions": [
    "contextMenus",
    "tabs",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5173/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Ouvrir l'Éditeur Accordéons"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
