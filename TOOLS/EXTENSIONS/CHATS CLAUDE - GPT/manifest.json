{
  "manifest_version": 3,
  "name": "AI Conversation Saver",
  "version": "1.0",
  "description": "Sauvegarde conversations Claude et ChatGPT",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://chatgpt.com/*"],
      "js": ["content.js"]
    }
  ],
    "icons": {
    "16": "favicon-16.png",
    "48": "favicon-32.png"
  }
}