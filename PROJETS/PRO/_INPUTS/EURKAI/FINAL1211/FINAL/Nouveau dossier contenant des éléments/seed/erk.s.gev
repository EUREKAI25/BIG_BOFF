# ============================================================
# EUREKAI SEED — ERK (EUREKAI Rule Kernel) v1.0
# ============================================================
# Contient:
# - Object:Language:ERK — le langage
# - Object:Rule:* — types de règles
# - Object:Method:Formula:* — formulas par catégorie
# - Object:Documentation:Specification:ERK — spec complète
# ============================================================

# ============================================================
# LANGUAGE ERK
# ============================================================

Object:Language:ERK
.name = ERK
.fullName = EUREKAI Rule Kernel
.version = 1.1.0
.description = Langage logique opératoire unifié d'EUREKAI pour les règles, méthodes, formules et diagnostics
.status = RELEASE_CANDIDATE

Object:Language:ERK IN LanguageList

# ============================================================
# RULE TYPES — Actions de règles
# ============================================================

Object:Rule
.description = Type racine des règles ERK
.syntax = <action>: <expression>
.example = must: this.name != null

Object:Rule IN RuleList

# --- Obligation ---
Object:Rule:Must
.action = must
.description = Obligation stricte — bloque si false
.effect = BLOCK + ERROR
.syntax = must: <expression>
.example = must: this.name != null AND this.name.length > 0

Object:Rule:Must IN RuleList

Object:Rule:MustNot
.action = must_not
.description = Interdiction stricte — bloque si true
.effect = BLOCK + ERROR
.syntax = must_not: <expression>
.example = must_not: this.status == "deleted" AND this.hasChildren == true

Object:Rule:MustNot IN RuleList

# --- Permission ---
Object:Rule:Allow
.action = allow
.description = Permission — refuse si false
.effect = DENY si false
.syntax = allow: <expression>
.example = allow: ctx.user.role IN ["admin", "editor"]

Object:Rule:Allow IN RuleList

Object:Rule:Deny
.action = deny
.description = Refus explicite — toujours refusé
.effect = DENY toujours
.syntax = deny: <expression>
.example = deny: ctx.user.banned == true

Object:Rule:Deny IN RuleList

# --- Prérequis ---
Object:Rule:Require
.action = require
.description = Prérequis — bloque si absent
.effect = BLOCK si absent
.syntax = require: <expression>
.example = require: this.parent != null

Object:Rule:Require IN RuleList

Object:Rule:Forbid
.action = forbid
.description = Interdiction absolue — critique
.effect = BLOCK + CRITICAL
.syntax = forbid: <expression>
.example = forbid: ctx.execution_request != null AND ctx.approval == null

Object:Rule:Forbid IN RuleList

# --- Activation ---
Object:Rule:Enable
.action = enable
.description = Activation conditionnelle
.effect = Désactivé si false
.syntax = enable: <expression>
.example = enable: IF this.priority == "high" THEN true ELSE this.hasApproval

Object:Rule:Enable IN RuleList

Object:Rule:Disable
.action = disable
.description = Désactivation conditionnelle
.effect = Activé si false
.syntax = disable: <expression>
.example = disable: this.deprecated == true

Object:Rule:Disable IN RuleList

# --- Vérification ---
Object:Rule:Check
.action = check
.description = Vérification souple — warning si false
.effect = WARNING (non bloquant)
.syntax = check: <expression>
.example = check: this.description.length >= 10

Object:Rule:Check IN RuleList

Object:Rule:Validate
.action = validate
.description = Validation structurelle — error si invalid
.effect = ERROR si invalid
.syntax = validate: <expression>
.example = validate: this.email MATCHES "^[a-z]+@[a-z]+\\.[a-z]+$"

Object:Rule:Validate IN RuleList

Object:Rule:Warn
.action = warn
.description = Avertissement — non bloquant
.effect = WARNING
.syntax = warn: <expression>
.example = warn: this.stock < 10

Object:Rule:Warn IN RuleList

# --- Suggestion ---
Object:Rule:Suggest
.action = suggest
.description = Suggestion IA — proposé, non imposé
.effect = Proposé
.syntax = suggest: IF <condition> THEN SUGGEST <action>
.example = suggest: IF this.score < 0.5 THEN SUGGEST improve_prompt(this.prompt, "clarity")

Object:Rule:Suggest IN RuleList

# ============================================================
# FORMULA CATEGORIES
# ============================================================

Object:Function:Formula
.description = Type racine des formulas ERK (style Excel)
.syntax = FORMULA <name> = <expression>

Object:Function:Formula IN FormulaList

Object:Method:Formula:Category
.description = Catégories de formulas

Object:Method:Formula:Category:Logic
.name = LOGIC
.description = Opérateurs logiques

Object:Method:Formula:Category:Comparison
.name = COMPARISON
.description = Opérateurs de comparaison

Object:Method:Formula:Category:String
.name = STRING
.description = Manipulation de chaînes

Object:Method:Formula:Category:Collection
.name = COLLECTION
.description = Manipulation de collections/arrays

Object:Method:Formula:Category:Existence
.name = EXISTENCE
.description = Tests d'existence et nullité

Object:Method:Formula:Category:Navigation
.name = NAVIGATION
.description = Navigation dans les structures

Object:Method:Formula:Category:Structure
.name = STRUCTURE
.description = Manipulation de structures/objets

Object:Method:Formula:Category:Math
.name = MATH
.description = Opérations mathématiques

Object:Method:Formula:Category:Date
.name = DATE
.description = Manipulation de dates

# ============================================================
# FORMULAS — LOGIC
# ============================================================

Object:Method:Formula:AND
.name = AND
.category = Logic
.description = Conjonction logique — true si tous les opérandes sont true
.syntax = <expr1> AND <expr2>
.input.type = bool, bool
.output.type = bool
.example = this.active == true AND this.approved == true
.priority = 2

Object:Method:Formula:AND IN FormulaList

Object:Method:Formula:OR
.name = OR
.category = Logic
.description = Disjonction logique — true si au moins un opérande est true
.syntax = <expr1> OR <expr2>
.input.type = bool, bool
.output.type = bool
.example = this.status == "active" OR this.status == "pending"
.priority = 3

Object:Method:Formula:OR IN FormulaList

Object:Method:Formula:NOT
.name = NOT
.category = Logic
.description = Négation logique — inverse la valeur booléenne
.syntax = NOT <expr>
.input.type = bool
.output.type = bool
.example = NOT this.deleted
.priority = 1

Object:Method:Formula:NOT IN FormulaList

Object:Method:Formula:XOR
.name = XOR
.category = Logic
.description = Ou exclusif — true si exactement un opérande est true
.syntax = <expr1> XOR <expr2>
.input.type = bool, bool
.output.type = bool
.example = this.optionA XOR this.optionB

Object:Method:Formula:XOR IN FormulaList

Object:Method:Formula:IF
.name = IF
.category = Logic
.description = Condition ternaire — retourne valeur selon condition
.syntax = IF(<condition>, <valeurSiVrai>, <valeurSiFaux>)
.input.type = bool, any, any
.output.type = any
.example = IF(this.score > 80, "Excellent", IF(this.score > 50, "Passable", "Insuffisant"))

Object:Method:Formula:IF IN FormulaList

# ============================================================
# FORMULAS — COMPARISON
# ============================================================

Object:Method:Formula:EQ
.name = EQ
.literal = ==
.category = Comparison
.description = Égalité stricte
.syntax = <expr1> == <expr2>
.input.type = any, any
.output.type = bool
.example = this.status == "active"

Object:Method:Formula:EQ IN FormulaList

Object:Method:Formula:NEQ
.name = NEQ
.literal = !=
.category = Comparison
.description = Inégalité
.syntax = <expr1> != <expr2>
.input.type = any, any
.output.type = bool
.example = this.status != "deleted"

Object:Method:Formula:NEQ IN FormulaList

Object:Method:Formula:GT
.name = GT
.literal = >
.category = Comparison
.description = Supérieur strict
.syntax = <expr1> > <expr2>
.input.type = number, number
.output.type = bool
.example = this.priority > 5

Object:Method:Formula:GT IN FormulaList

Object:Method:Formula:GTE
.name = GTE
.literal = >=
.category = Comparison
.description = Supérieur ou égal
.syntax = <expr1> >= <expr2>
.input.type = number, number
.output.type = bool
.example = this.score >= 80

Object:Method:Formula:GTE IN FormulaList

Object:Method:Formula:LT
.name = LT
.literal = <
.category = Comparison
.description = Inférieur strict
.syntax = <expr1> < <expr2>
.input.type = number, number
.output.type = bool
.example = this.stock < 10

Object:Method:Formula:LT IN FormulaList

Object:Method:Formula:LTE
.name = LTE
.literal = <=
.category = Comparison
.description = Inférieur ou égal
.syntax = <expr1> <= <expr2>
.input.type = number, number
.output.type = bool
.example = this.age <= 65

Object:Method:Formula:LTE IN FormulaList

Object:Method:Formula:IN
.name = IN
.category = Comparison
.description = Appartenance à une liste
.syntax = <expr> IN <array>
.input.type = any, array
.output.type = bool
.example = this.country IN ["FR", "ES", "IT"]

Object:Method:Formula:IN IN FormulaList

Object:Method:Formula:NOT_IN
.name = NOT_IN
.category = Comparison
.description = Non-appartenance à une liste
.syntax = <expr> NOT IN <array>
.input.type = any, array
.output.type = bool
.example = this.status NOT IN ["deleted", "archived"]

Object:Method:Formula:NOT_IN IN FormulaList

Object:Method:Formula:MATCHES
.name = MATCHES
.category = Comparison
.description = Correspondance regex
.syntax = <string> MATCHES <pattern>
.input.type = string, string
.output.type = bool
.example = this.email MATCHES "^[a-z]+@[a-z]+\\.[a-z]+$"

Object:Method:Formula:MATCHES IN FormulaList

Object:Method:Formula:CONTAINS
.name = CONTAINS
.category = Comparison
.description = Contient un élément
.syntax = <collection> CONTAINS <element>
.input.type = array|string, any
.output.type = bool
.example = this.tags CONTAINS "urgent"

Object:Method:Formula:CONTAINS IN FormulaList

