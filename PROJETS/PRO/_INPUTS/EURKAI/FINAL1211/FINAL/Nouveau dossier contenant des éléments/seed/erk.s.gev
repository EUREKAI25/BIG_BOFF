Object:Method:Formula:ISNULL
.name = ISNULL
.category = Existence
.description = Test si null
.syntax = ISNULL(<expr>)
.input.type = any
.output.type = bool
.example = ISNULL(this.deletedAt)

Object:Method:Formula:ISNULL IN FormulaList

Object:Method:Formula:EXISTS
.name = EXISTS
.category = Existence
.description = Test si existe (non null)
.syntax = EXISTS(<expr>)
.input.type = any
.output.type = bool
.example = EXISTS(this.parent)

Object:Method:Formula:EXISTS IN FormulaList

Object:Method:Formula:IS_EMPTY
.name = IS_EMPTY
.category = Existence
.description = Test si vide (null, "", [], {})
.syntax = IS_EMPTY(<expr>)
.input.type = any
.output.type = bool
.example = IS_EMPTY(this.children)

Object:Method:Formula:IS_EMPTY IN FormulaList

Object:Method:Formula:COALESCE
.name = COALESCE
.category = Existence
.description = Retourne la première valeur non-null
.syntax = COALESCE(<expr1>, <expr2>, ...)
.input.type = any...
.output.type = any
.example = COALESCE(this.nickname, this.name, "Anonymous")

Object:Method:Formula:COALESCE IN FormulaList

