.output.type = string
.example = LOWER(this.email)

Object:Method:Formula:LOWER IN FormulaList

Object:Method:Formula:TRIM
.name = TRIM
.category = String
.description = Supprime les espaces début/fin
.syntax = TRIM(<string>)
.input.type = string
.output.type = string
.example = TRIM(this.input)

Object:Method:Formula:TRIM IN FormulaList

Object:Method:Formula:REPLACE
.name = REPLACE
.category = String
.description = Remplace des occurrences
.syntax = REPLACE(<string>, <old>, <new>)
.input.type = string, string, string
.output.type = string
.example = REPLACE(this.text, "foo", "bar")

Object:Method:Formula:REPLACE IN FormulaList

Object:Method:Formula:SUBSTRING
.name = SUBSTRING
.category = String
.description = Extrait une sous-chaîne
.syntax = SUBSTRING(<string>, <start>, <length>)
