.description = Découpe une chaîne en tableau
.syntax = SPLIT(<string>, <separator>)
.input.type = string, string
.output.type = array
.example = SPLIT(this.tags, ",")

Object:Method:Formula:SPLIT IN FormulaList

Object:Method:Formula:JOIN
.name = JOIN
.category = String
.description = Joint un tableau en chaîne
.syntax = JOIN(<array>, <separator>)
.input.type = array, string
.output.type = string
.example = JOIN(this.tags, ", ")

Object:Method:Formula:JOIN IN FormulaList

Object:Method:Formula:UPPER
.name = UPPER
.category = String
.description = Convertit en majuscules
.syntax = UPPER(<string>)
.input.type = string
.output.type = string
.example = UPPER(this.code)

Object:Method:Formula:UPPER IN FormulaList

Object:Method:Formula:LOWER
.name = LOWER
.category = String
.description = Convertit en minuscules
.syntax = LOWER(<string>)
