.output.type = string
.example = SUBSTRING(this.code, 0, 3)

Object:Method:Formula:SUBSTRING IN FormulaList

Object:Method:Formula:LEN
.name = LEN
.category = String
.description = Longueur de la chaîne
.syntax = LEN(<string>)
.input.type = string
.output.type = int
.example = LEN(this.name) > 0

Object:Method:Formula:LEN IN FormulaList

