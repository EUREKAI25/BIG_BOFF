Object:Structure:Fractal:Vector:V_StateRuleErk:
  .default = |
    EXEC Rule.Validate.State(
      input = {
        fromState: $fromState,
        toState: $toState,
        allowedTransitions: $allowedTransitions,
        target: $target,
        context: $context
      },
      output = {
        ok: $ok,
        issue: $issue
      }
    )
    IF($ok, OK(), ISSUE($issue))

