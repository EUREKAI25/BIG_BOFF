  .default = ""

Object:Structure:Fractal:Vector:V_BehavioralRuleTrigger:
  .default = ""

Object:Structure:Fractal:Vector:V_BehavioralRuleAction:
  .default = ""

Object:Structure:Fractal:Vector:V_BehavioralRuleErk:
  .default = |
    EXEC Rule.Execute(
      input = {
        trigger: $trigger,
        action: $action,
        target: $target,
        context: $context
      },
      output = {
        ok: $ok,
        issue: $issue
      }
    )
    IF($ok, OK(), ISSUE($issue))

Object:Structure:Fractal:Vector:V_StateRuleName:
  .default = "Règle d'état"

Object:Structure:Fractal:Vector:V_StateRuleDescription:
  .default = "Règle sur les états et transitions autorisées."

