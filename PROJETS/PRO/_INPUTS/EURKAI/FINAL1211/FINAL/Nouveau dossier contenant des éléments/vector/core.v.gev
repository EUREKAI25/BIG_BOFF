#region === RULES ===

Object:Structure:Fractal:Vector:V_StructuralRuleName:
  .default = {"FR": "Règle structurelle", "EN": "Structural rule"}

Object:Structure:Fractal:Vector:V_StructuralRuleDescription:
  .default = {"FR": "Règle qui décrit la forme attendue d'un objet (attributs, types, relations, bundles, format).", "EN": "Rule describing the expected shape of an object."}

Object:Structure:Fractal:Vector:V_StructuralRuleQuestion:
  .default = {"FR": "Quelle règle de structure s'applique à cet objet ?", "EN": "Which structural rule applies to this object?"}

Object:Structure:Fractal:Vector:V_StructuralRuleSeverity:
  .default = "info"

Object:Structure:Fractal:Vector:V_StructuralRuleConstraintLevel:
  .default = "MAY"

Object:Structure:Fractal:Vector:V_StructuralRuleScope:
  .default = []

Object:Structure:Fractal:Vector:V_StructuralRuleCondition:
  .default = ""

Object:Structure:Fractal:Vector:V_StructuralRuleErrorMessage:
  .default = ""

Object:Structure:Fractal:Vector:V_SchemaRuleConstraintPattern:
  .default = ""

Object:Structure:Fractal:Vector:V_SchemaRuleRequiredKeyword:
  .default = ""

Object:Structure:Fractal:Vector:V_AttributeDeclaredRuleErk:
  .default = |
    FOREACH attr IN $target.attributeList {
      attrType = attr.name.toUpperFirst()
      EXISTS("Object:Attribute:" + attrType) 
        OR ISSUE("Attribut ." + attr.name + " non déclaré dans Object:Attribute")
    }

#endregion

# rule.v.gev 
Object:Structure:Fractal:Vector:V_RuleName:
  .default = "Rule"

Object:Structure:Fractal:Vector:V_RuleDescription:
  .default = ""

Object:Structure:Fractal:Vector:V_RuleQuestion:
  .default = ""

Object:Structure:Fractal:Vector:V_RuleSeverity:
  .default = "info"

Object:Structure:Fractal:Vector:V_RuleConstraintLevel:
  .default = "MAY"

Object:Structure:Fractal:Vector:V_RuleScope:
  .default = []

Object:Structure:Fractal:Vector:V_RuleCondition:
  .default = ""

Object:Structure:Fractal:Vector:V_RuleErrorMessage:
  .default = ""

Object:Structure:Fractal:Vector:V_RuleErk:
  .default = |
    EXEC Rule.Validate(
      input = {
        target: $target,
        context: $context
      },
      output = {
        ok: $ok,
        issue: $issue
      }
    )
    IF($ok, OK(), ISSUE($issue))

Object:Structure:Fractal:Vector:V_StructuralRuleName:
  .default = "Règle structurelle"

Object:Structure:Fractal:Vector:V_StructuralRuleDescription:
  .default = "Règle qui décrit la forme attendue d'un objet (attributs, types, relations, bundles, format)."

Object:Structure:Fractal:Vector:V_StructuralRuleQuestion:
  .default = "Quelle règle de structure s'applique à cet objet ?"

Object:Structure:Fractal:Vector:V_StructuralRuleSeverity:
  .default = "info"

Object:Structure:Fractal:Vector:V_StructuralRuleConstraintLevel:
  .default = "MAY"

Object:Structure:Fractal:Vector:V_StructuralRuleScope:
  .default = []

Object:Structure:Fractal:Vector:V_StructuralRuleCondition:
  .default = ""

Object:Structure:Fractal:Vector:V_StructuralRuleErrorMessage:
  .default = ""

Object:Structure:Fractal:Vector:V_StructuralRuleErk:
  .default = |
    EXEC Rule.Validate(
      input = {
        target: $target,
        source_text: $source_text,
        source_kind: $source_kind,
        context: $context
      },
      output = {
        ok: $ok,
        issue: $issue
      }
    )
    IF($ok, OK(), ISSUE($issue))

Object:Structure:Fractal:Vector:V_SchemaRuleName:
  .default = "Règle de schéma"

Object:Structure:Fractal:Vector:V_SchemaRuleDescription:
  .default = "Contraintes sur présence/absence d'attributs, types attendus, cardinalités et structure."

Object:Structure:Fractal:Vector:V_SchemaRuleQuestion:
  .default = "Quels attributs/types/cardis doivent exister pour cet objet ?"

Object:Structure:Fractal:Vector:V_SchemaRuleSeverity:
  .default = "info"

Object:Structure:Fractal:Vector:V_SchemaRuleConstraintLevel:
  .default = "MAY"

Object:Structure:Fractal:Vector:V_SchemaRuleScope:
  .default = []

Object:Structure:Fractal:Vector:V_SchemaRuleCondition:
  .default = ""

Object:Structure:Fractal:Vector:V_SchemaRuleErrorMessage:
  .default = ""

Object:Structure:Fractal:Vector:V_SchemaRuleConstraintPattern:
  .default = ""

Object:Structure:Fractal:Vector:V_SchemaRuleRequiredKeyword:
  .default = ""

Object:Structure:Fractal:Vector:V_SchemaRuleRequiredSlot:
  .default = ""

Object:Structure:Fractal:Vector:V_SchemaRuleErk:
  .default = |
    EXEC Rule.Validate.Schema(
      input = {
        target: $target,
        schema: $schema,
        context: $context
      },
      output = {
        ok: $ok,
        issue: $issue
      }
    )
    IF($ok, OK(), ISSUE($issue))

Object:Structure:Fractal:Vector:V_FormatRuleName:
  .default = "Règle de format"

Object:Structure:Fractal:Vector:V_FormatRuleDescription:
  .default = "Contraintes sur le format des valeurs (regex, format attendu)."

Object:Structure:Fractal:Vector:V_FormatRuleQuestion:
  .default = "Quel format cette valeur doit-elle respecter ?"

Object:Structure:Fractal:Vector:V_FormatRuleSeverity:
  .default = "info"

Object:Structure:Fractal:Vector:V_FormatRuleConstraintLevel:
  .default = "MAY"

Object:Structure:Fractal:Vector:V_FormatRuleScope:
  .default = []

Object:Structure:Fractal:Vector:V_FormatRuleCondition:
  .default = ""

Object:Structure:Fractal:Vector:V_FormatRuleErrorMessage:
  .default = ""

Object:Structure:Fractal:Vector:V_FormatRuleRegex:
  .default = ""

Object:Structure:Fractal:Vector:V_FormatRuleFormat:
  .default = ""

Object:Structure:Fractal:Vector:V_FormatRuleErk:
  .default = |
    EXEC Rule.Validate.Format(
      input = {
        target: $target,
        source_text: $source_text,
        regex: $regex,
        format: $format,
        context: $context
      },
      output = {
        ok: $ok,
        issue: $issue
      }
    )
    IF($ok, OK(), ISSUE($issue))

Object:Structure:Fractal:Vector:V_CardinalityRuleName:
  .default = "Règle de cardinalité"

Object:Structure:Fractal:Vector:V_CardinalityRuleDescription:
  .default = "Contraintes min/max sur le nombre d'éléments."

Object:Structure:Fractal:Vector:V_CardinalityRuleQuestion:
  .default = "La cardinalité respecte-t-elle les bornes min/max ?"

Object:Structure:Fractal:Vector:V_CardinalityRuleSeverity:
  .default = "info"

Object:Structure:Fractal:Vector:V_CardinalityRuleConstraintLevel:
  .default = "MAY"

Object:Structure:Fractal:Vector:V_CardinalityRuleScope:
  .default = []

Object:Structure:Fractal:Vector:V_CardinalityRuleCondition:
  .default = ""

Object:Structure:Fractal:Vector:V_CardinalityRuleErrorMessage:
  .default = ""

Object:Structure:Fractal:Vector:V_CardinalityRuleMin:
  .default = 0

Object:Structure:Fractal:Vector:V_CardinalityRuleMax:
  .default = -1

Object:Structure:Fractal:Vector:V_CardinalityRuleErk:
  .default = |
    EXEC Rule.Validate.Cardinality(
      input = {
        target: $target,
        min: $min,
        max: $max,
        context: $context
      },
      output = {
        ok: $ok,
        issue: $issue
      }
    )
    IF($ok, OK(), ISSUE($issue))

Object:Structure:Fractal:Vector:V_BehavioralRuleName:
  .default = "Règle comportementale"

Object:Structure:Fractal:Vector:V_BehavioralRuleDescription:
  .default = "Règle sur le comportement (événement déclencheur et action)."

Object:Structure:Fractal:Vector:V_BehavioralRuleQuestion:
  .default = "Quel comportement est déclenché et quelle action s'exécute ?"

Object:Structure:Fractal:Vector:V_BehavioralRuleSeverity:
  .default = "info"

Object:Structure:Fractal:Vector:V_BehavioralRuleConstraintLevel:
  .default = "MAY"

Object:Structure:Fractal:Vector:V_BehavioralRuleScope:
  .default = []

