Object:Structure:Fractal:Vector:V_PermissionRuleAction:
  .default = ""

Object:Structure:Fractal:Vector:V_PermissionRuleResource:
  .default = ""

Object:Structure:Fractal:Vector:V_PermissionRuleErk:
  .default = |
    EXEC Rule.Validate.Permission(
      input = {
        actor: $actor,
        action: $action,
        resource: $resource,
        context: $context
      },
      output = {
        ok: $ok,
        issue: $issue
      }
    )
    IF($ok, OK(), ISSUE($issue))

Object:Structure:Fractal:Vector:V_ValidationRuleName:
  .default = "Règle de validation"

Object:Structure:Fractal:Vector:V_ValidationRuleDescription:
  .default = "Règle de validation métier (validator + hooks succès/échec)."

Object:Structure:Fractal:Vector:V_ValidationRuleQuestion:
  .default = "La validation réussit-elle et quels hooks s'appliquent ?"

Object:Structure:Fractal:Vector:V_ValidationRuleSeverity:
  .default = "info"

Object:Structure:Fractal:Vector:V_ValidationRuleConstraintLevel:
  .default = "MAY"

Object:Structure:Fractal:Vector:V_ValidationRuleScope:
  .default = []

Object:Structure:Fractal:Vector:V_ValidationRuleCondition:
  .default = ""

Object:Structure:Fractal:Vector:V_ValidationRuleErrorMessage:
  .default = ""

Object:Structure:Fractal:Vector:V_ValidationRuleValidator:
  .default = ""

Object:Structure:Fractal:Vector:V_ValidationRuleOnSuccess:
  .default = ""

Object:Structure:Fractal:Vector:V_ValidationRuleOnFailure:
  .default = ""

Object:Structure:Fractal:Vector:V_ValidationRuleErk:
  .default = |
    EXEC Rule.Validate.Business(
      input = {
        validator: $validator,
        target: $target,
        context: $context
      },
      output = {
        ok: $ok,
        issue: $issue
      }
    )
    IF($ok, EXEC Hook($onSuccess), EXEC Hook($onFailure))

Object:Structure:Fractal:Vector:V_ComputedRuleName:
  .default = "Règle calculée"

Object:Structure:Fractal:Vector:V_ComputedRuleDescription:
  .default = "Règle de calcul (formule, dépendances, cache)."

Object:Structure:Fractal:Vector:V_ComputedRuleQuestion:
  .default = "La valeur calculée est-elle correcte ?"

Object:Structure:Fractal:Vector:V_ComputedRuleSeverity:
  .default = "info"

Object:Structure:Fractal:Vector:V_ComputedRuleConstraintLevel:
  .default = "MAY"

Object:Structure:Fractal:Vector:V_ComputedRuleScope:
  .default = []

Object:Structure:Fractal:Vector:V_ComputedRuleCondition:
  .default = ""

Object:Structure:Fractal:Vector:V_ComputedRuleErrorMessage:
  .default = ""

Object:Structure:Fractal:Vector:V_ComputedRuleFormula:
  .default = ""

Object:Structure:Fractal:Vector:V_ComputedRuleDependencies:
  .default = []

Object:Structure:Fractal:Vector:V_ComputedRuleCache:
  .default = false

Object:Structure:Fractal:Vector:V_ComputedRuleErk:
  .default = |
    EXEC Rule.Compute(
      input = {
        formula: $formula,
        dependencies: $dependencies,
        cache: $cache,
        target: $target,
        context: $context
      },
      output = {
        ok: $ok,
        issue: $issue
      }
    )
    IF($ok, OK(), ISSUE($issue))

Object:Structure:Fractal:Vector:V_AttributeDeclaredRuleErk:
  .default = |
    FOREACH attr IN $target.attributeList {
      attrType = attr.name.toUpperFirst()
      EXISTS("Object:Attribute:" + attrType) 
        OR ISSUE("Attribut ." + attr.name + " non déclaré dans Object:Attribute")
    }