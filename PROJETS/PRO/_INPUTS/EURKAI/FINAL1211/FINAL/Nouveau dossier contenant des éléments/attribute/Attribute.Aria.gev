## Object:Attribute:Aria:
## Attributs d'accessibilité ARIA
## Tous les sites doivent être accessibles

Object:Attribute:Aria:
  .vector = {"required": true}
  .AriaAttributeList = {"type": "list", "of": "Object:Attribute:Aria"}

## ============================================
## Spécialisations Aria
## ============================================

Object:Attribute:Aria:Role:
  .value = {}
  ## Valeurs: navigation, main, banner, contentinfo, complementary, 
  ##          region, article, button, link, dialog, alert, etc.

Object:Attribute:Aria:Label:
  .value = {}
  ## Texte descriptif pour lecteurs d'écran

Object:Attribute:Aria:Labelledby:
  .value = {}
  ## Référence id d'un élément qui labellise

Object:Attribute:Aria:Describedby:
  .value = {}
  ## Référence id d'un élément qui décrit

Object:Attribute:Aria:Expanded:
  .value = {"type": "boolean", "default": false}
  ## Pour accordéons, menus déroulants

Object:Attribute:Aria:Hidden:
  .value = {"type": "boolean", "default": false}
  ## Masquer aux lecteurs d'écran

Object:Attribute:Aria:Controls:
  .value = {}
  ## Référence id de l'élément contrôlé

Object:Attribute:Aria:Live:
  .value = {}
  ## Valeurs: polite, assertive, off
  ## Pour zones de contenu dynamique

Object:Attribute:Aria:Atomic:
  .value = {"type": "boolean", "default": false}
  ## Annoncer tout le contenu ou seulement les changements

Object:Attribute:Aria:Current:
  .value = {}
  ## Valeurs: page, step, location, date, time, true, false

Object:Attribute:Aria:Selected:
  .value = {"type": "boolean", "default": false}
  ## Pour onglets, options

Object:Attribute:Aria:Disabled:
  .value = {"type": "boolean", "default": false}
  ## Élément désactivé

Object:Attribute:Aria:Required:
  .value = {"type": "boolean", "default": false}
  ## Champ obligatoire

Object:Attribute:Aria:Invalid:
  .value = {"type": "boolean", "default": false}
  ## Valeur invalide
