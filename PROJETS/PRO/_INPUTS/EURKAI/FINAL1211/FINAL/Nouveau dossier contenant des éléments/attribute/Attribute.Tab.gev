## Object:Attribute:Tab:
## Navigation clavier pour accessibilité

Object:Attribute:Tab:
  .vector = {"required": true}
  .index = {}
  ## tabindex: 
  ##   0 = focusable dans l'ordre naturel du DOM
  ##  -1 = focusable uniquement par script (skip dans tab order)
  ##   n = ordre personnalisé (éviter si possible)
  
  .order = {}
  ## Ordre logique de navigation (si différent du DOM)
  
  .TabList = {"type": "list", "of": "Object:Attribute:Tab"}
