#region === OBJECT ===
Object:
  .name = V_ObjectName
  .elementList = V_ObjectElementList
  .description = V_ObjectDescription
  .createdBy= V_OBjectCreatedBy
  .createdAt= V_OBjectCreatedAt
  .udatedBy= V_OBjectUpdatedBy
  .updatedBy= V_OBjectUpdatedBy
  .version= V_OBjectVersion
  .level = V_Object
  .mode = V_Object
  .nature = V_Object
  .count = V_ObjectCount
  .automated = true
  .scan = V_ObjectScan   


#endregion

#region === ATTRIBUTE ===
Object:Attribute:
  .name = V_ObjectName
  .description =V_AttributeDescription
  .multiple = V_ElementCardinality
  Attribute IN Object.AttributeList

Object:Attribute:Filter:
  .scope = ""


Object:Attribute:AttributeList:
  AttributeList IN ElementList

Object:Attribute:MethodList:
  AttributeList IN ElementList AND IDPlane

Object:Attribute:RuleList:
  AttributeList IN ElementList AND Plane

Object:Attribute:RelationList:
  RelationList IN ElementList AND IDPlane

Object:Attribute:OptionList:
  OptionList IN ElementList AND IOPlane

Object:Attribute:AliasList:
  AliasList IN AttributeList AND IOPlane



Object:Attribute:Property:

Object:Attribute:Autonomous:

Object:Attribute:FName:
  .name = V_FNameAttribute # "fname"
  FName IN AttributeList
  
Object:Attribute:LName:
  .name = V_LNameAttribute # "lname"
  LName IN AttributeList
  
Object:Attribute:Automated:
  .name = "Automated"
  .description.FR = "Attribut pour objets auto-générés"
  .description.EN = "Attribute for auto-generated objects"
  .automated = true
  Automated IN Attribute.ChildList

Object:Attribute:Description:
  .name = "Description"
  Description IN AttributeList
Object:Question:

Object:Attribute:
Object:Schema:
Object:Attribute:

Object:Attribute:
  .name = "Attribute"
  .multiple = "undefined"
 
