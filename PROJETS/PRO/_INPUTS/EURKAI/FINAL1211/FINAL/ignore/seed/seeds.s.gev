#region === BEHAVIOR ===
Object:Behavior:
  .name: "Behavior"
  .description: "Comportement appliqué à un scenario"
  .Behavior depends_on Scenario



Object:Behavior:LoopBehavior:
  LoopBehavior depends_on ExecuteStep**

Object:Behavior:LoopBehavior:SequentialLoopBehavior:
    .description: "Exécution des scénarios strictement séquentielles"

Object:Behavior:LoopBehavior:ParallelLoopBehavior:
  .description: "Exécution des scénarios en parallèle"

Object:Behavior:LoopBehavior:BatchLoopBehavior:
  .description: "Exécution des scénarios par lots"

Object:Behavior:LoopBehavior:ThrottledLoopBehavior:
  .description: "Exécution des scénarios avec débit maximal (rate_limit)"
  RateLimitRule 


Object:Behavior:RunBehavior:
  .name: "RunBehavior"
  .description:  RunBehavior depends_on Step

Object:Behavior:TraverseBehavior:
  .name: "TraverseBehavior"
  .description:
  TraverseBehavior depends_on GetStep


#endregion

