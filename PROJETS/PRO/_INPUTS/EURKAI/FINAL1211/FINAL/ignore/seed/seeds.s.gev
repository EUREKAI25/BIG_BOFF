#region === METHOD ===
Object:Function:
  .name = "Function"
  .input = V_FunctionInput
  .output = V_FunctionOutput

Object:Function:Method:
  .name = "Method"
  .hookBeforeList = V_MethodHookBeforeList
  .hookAfterList = V_MethodHookAfterList

Object:Method:CentralMethod:
  .name = "CentralMethod"
  .description = "Méthode centrale du système"
  .layer = 2-METHODS

Object:Method:CentralMethod:Create:
  .name = "Create"
  .description = "Méthode centrale Create"
  Create depends_on Object

Object:Method:CentralMethod:Read:
  .name = "Read"
  .description = "Méthode centrale Read"
  Read depends_on Object

Object:Method:CentralMethod:Update:
  .name = "Update"
  .description = "Méthode centrale Update"
  Update depends_on Object

Object:Method:CentralMethod:Delete:
  .name = "Delete"
  .description = "Méthode centrale Delete"
  Delete depends_on Object

Object:Method:CentralMethod:Orchestrate:
  .name = "Orchestrate"
  .description = "Coordonne l’exécution des scénarios et des hooks""
  Orchestrate IN Object.MethodList

Object:Method:CentralMethod:Engage:
  .name = "Engage"
  .description = "Méthode centrale Engage"
  Engage depends_on Object

Object:Method:SecondaryMethod:
  .name = "SecondaryMethod"
  .description = "Méthode secondaire déclinée d'une méthode centrale"
  SecondaryMethod IN CentralMethod.DependencyList

Object:Method:SecondaryMethod:Generate:
  .name = "Generate"
  Generate IN Automated.MethodList
  Generate depends_on Create

Object:Method:SecondaryMethod:GlobalRecursiveMethod:
  .name = "GlobalRecursiveMethod"
  .description = "construit un dict de nodes par parcours récursif"
  GlobalRecursiveMethod depends_on Orchestrate

Object:Method:SecondaryMethod:Validate:
  .name = "Validate"

Object:Method:SecondaryMethod:Walk:
  .name= "Walk" 
  .description = {"FR": "Parcourt un objet et ses enfants", "EN": "Traverses an object and its children"}
  Walk IN Walker.MethodList
  .input = V_WalkInput
  .output = V_WalkOutput
  .hooks = V_WalkHookAfterList
  Walk depends_on Read

Object:Method:SecondaryMethod:Count:
  .name = "Count"
  .description = "Retourne le nombre d'éléments / la taille de l'objet"
  Count IN ObjectMethodList
  Count depends_on Read

Object:Method:SecondaryMethod:Reset:
  .name = "Reset"
  .description = "Restaure les objets à leur état default"
  Reset depends_on Update
 
Object:Method:SecondaryMethod:Count:
  .name = "Count"
  .description = "Retourne le nombre d'éléments / la taille de l'objet"
  Count IN ObjectMethodList



Object:Method:Scenario:
  .name = V_ScenarioName
  .description = V_ScenarioDescription
  .milestoneList = V_MilestoneList
  .goal = V_ScenarioGoal
  .inputList = V_ScenarioInputList
  .outputList = V_ScenarioOutputList
  .validationRule = V_ScenarioValidationRule




Object:Method:Scenario:Step:
  .name = V_StepName
  .order = V_StepOrder
  .method = V_StepMethod
  Step IN StepList
  StepList IN Milestone.ElementList

Object:Method:Scenario:Step:GetStep:
  .name = "GetStep"
  .description = "applique TraverseBehavior et retourne les cibles"

  .order = 1

Object:Method:Scenario:Step:ExecuteStep:
  .name = "ExecuteStep"
  .description = "applique LoopBehavior et déclenche scan.value depuis chaque noeud"
  .order = 2


Object:Method:Scenario:Step:ValidateStep:
  .name = "ValidateStep"
  .description = "Valide les résultats"
  .order = 3

Object:Method:Scenario:Step:RenderStep:
  .name = "RenderStep"
  .description = "rend/présente/serialise les résultats"
  .order = 4


Object:Method:Scenario:Milestone:
  .name = V_MilestoneName
  .order = V_MilestoneOrder
  .stepList = V_StepList
  Milestone IN MilestoneList
  MilestoneList IN Scenario.ElementList



Object:Method:Scenario:BootstrapScenario:
Object:Method:Scenario:GhostScenario:
  .name = "GhostScenario"
  .description = ""

Object:Method:Formula:
  name: "Formulas"
  Formula depends_on Logic 

  #endregion

#region === RULE ===

Object:Rule:
  .name = "Rule"
  .condition = V_RuleCondition

Object:Rule:ValidationRule:
  .name = "ValidationRule"

Object:Rule:CreateRule:
  .name = "CreateRule"

Object:Rule:FormatRule:
  .name = "FormatRule"
  .pattern = V_FormatPattern
#endregion

#region === RELATION ===


Object:Alias:Relation:
  .name = "Relation"
  Relation IN Object.RelationList



#endregion

#region ===  CONFIG ==========

Object:Config:
  .name = "Config"

Object:Config:Vector:
  .name = "Vector"
  .automated = true

#endregion

#region ===  ALIAS ==========

Object:Alias:
  .name = "Alias"
  .automated = true
  .description = V_AliasDescription
  .target = V_AliasTarget       # ce que l'alias désigne
  Alias IN Object.AttributeList.AliasList

Object:Alias:SyntaxAlias:
  .name = "SyntaxAlias"
  .description = V_SyntaxAlias
  .target = V_SyntaxAliasTarget

Object:Alias:SyntaxAlias:Relation:
  .name = "Relation"
  .description = V_RelationDescription
  .target = V_AliasTarget
  Relation IN SyntaxAlias.ChildList

Object.ChildList.Element IN

Object:Alias:SyntaxAlias:Relation:DependsOn:
  .name = "depends_on"
  .query = "{{source}} IN {{target}}.DependencyList"

Object:Alias:SyntaxAlias:Relation:RelatedTo:
  .name = "related_to"
  .query = "{{source}} IN {{target}}.RelatedList"

Object:Alias:SyntaxAlias:Relation:InheritsFrom:
  .name = "inherits_from"
  .query = "{{source}} IN {{target}}.ChildList"

Object:Alias:QueryAlias:
  .name = "QueryAlias"
  .description = {"FR": "Alias retournant un résultat de requête", "EN": "Alias returning a query result"}
  .target = V_QueryAliasTarget
  .method = V_QueryMethod

#endregion

