#region === STRUCTURE ===
Object:Structure:
  .name = "Structure"
  .description.FR = "Définit comment un objet est structuré"
  .description.EN = "Defines how an object is structured"
  related_to Object

Object:Structure:Dict:
  .name = "Dict"
  .description.FR = "Tout objet est un dictionnaire clé-valeur"
  .description.EN = "Every object is a key-value dictionary"
  Dict IN ObjectAttributeList
  .coucou = "coucou"

Object:Structure:List:
  .name = "List"
  .description.FR = "Dictionnaire avec clés sans impact"
  .description.EN = "Dictionary with irrelevant keys"
  List IN DictList

Object:Structure:List:OrderedList:
  .name = "OrderedList"
  .description.FR = "Liste avec clés classées selon une règle de tri"
  .description.EN = "List with keys sorted by a rule"
  .sortRule = V_SortRule

Object:Structure:Element:
  .name = "Element"
  .description.FR = "Objet faisant partie d'une liste"
  .description.EN = "Object that belongs to a list"
  .cardinality = "undefined"
  Element IN ElementList.*

Object:Structure:List:ObjectList:
  .name = V_ObjectList #"ObjectList"
  .description.FR = "Liste des éléments d'un objet"
  .description.EN = "List of element of an object"
  ElementList IN ObjectList
  
Object:Structure:List:ElementList:
  .name = V_ElementList #"ElementList"
  .description.FR = "Liste des listes d'éléments d'un objet"
  .description.EN = "List of element lists of an object"
  ElementList IN ObjectList

Object:Structure:List:RuleList:
  AttributeList IN ElementList

Object:Structure:List:ChildList:
  .name = "ChildList"
  .description = {"FR": "Liste des enfants directs (déduite du lineage)", "EN": "List of direct children (inferred from lineage)"}
  ChildList IN Object.ElementList

Object:Structure:Dataset:Planning:
  Planning related_to Time

Object:Structure:Dataset:
  .name = V_ElementList #"ElementList"

Object:Structure:Dataset:Catalog:
  .name = "Catalog"

Object:Structure:Dataset:VectorCatalog:
  .name = "VectorCatalog"

Object:Structure:Dataset:Table:
  .name = "Table"

Object:Structure:Fractal:

Object:Structure:Fractal:Vector:

Object:Structure:Fractal:Plane:

Object:Structure:Fractal:Plane:ExternalPlane:
Object:Structure:Fractal:Plane:TransversalPlane:

Object:Structure:Fractal:Plane:TransversalPlane:IDPlane:

Object:Structure:Fractal:Plane:TransversalPlane:IRPlane:
Object:Structure:Fractal:Plane:TransversalPlane:IOPlane:
Object:Structure:Fractal:Plane:TransversalPlane:VDPlane:
Object:Structure:Fractal:Plane:TransversalPlane:VRPlane:
Object:Structure:Fractal:Plane:TransversalPlane:VOPlane:
Object:Structure:Fractal:Plane:TransversalPlane:CDPlane:
Object:Structure:Fractal:Plane:TransversalPlane:CRPlane:
Object:Structure:Fractal:Plane:TransversalPlane:COPlane:

Object:Structure:Container:
  .name = "Container"

Object:Structure:Container:Wrapper:
  .name = "Wrapper" # je voudrais un fascia généralisé mais les lists nesont pas des containers - relation assemble possible ? souhaiable ?
  .description = 
  .format = V_WrapperFormat
  Wrapper related_to Container
#endregion

#region === RULE ===
Object:Rule:

Object:Rule:ResolutionRule:
  .name = "ResolutionRule"
  .description = "définit comment Get "
  .direction = V_TraverseDirection        # up | down | global
  .depth = V_TraverseDepth
  .order = V_TraverseOrder                # DFS | BFS
  .stopCondition = V_TraverseStopCondition
  .depends_on = GetStep


Object:Rule:ResolutionRule:Recursive:
  .name = "RecursiveRule"
  .description = "définit comment Get construit un dict de nodes par parcours récursif"


#endregion
