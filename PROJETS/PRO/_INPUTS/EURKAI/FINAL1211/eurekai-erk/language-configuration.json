{
  "comments": {"lineComment": "#"},
  "brackets": [["[", "]"], ["(", ")"], ["{", "}"]],
  "autoClosingPairs": [
    {"open": "\"", "close": "\""},
    {"open": "[", "close": "]"},
    {"open": "(", "close": ")"},
    {"open": "{", "close": "}"}
  ],
  "surroundingPairs": [
    ["\"", "\""],
    ["[", "]"],
    ["(", ")"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*#\\s*={3,}",
      "end": "^\\s*#\\s*={3,}"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^[A-Z][A-Za-z0-9_:]*:$",
    "decreaseIndentPattern": "^\\s*$"
  }
}
