{
  "scopeName": "source.erk",
  "name": "ERK",
  "patterns": [
    {"include": "#comments"},
    {"include": "#lineage"},
    {"include": "#attribute"},
    {"include": "#relation"},
    {"include": "#vector"},
    {"include": "#string"},
    {"include": "#number"},
    {"include": "#keyword"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {"match": "#.*$", "name": "comment.line.hash.erk"},
        {"match": "//.*$", "name": "comment.line.double-slash.erk"}
      ]
    },
    "lineage": {
      "match": "^([A-Z][A-Za-z0-9_]*(?::[A-Z][A-Za-z0-9_]*)*):$",
      "captures": {
        "1": {"name": "entity.name.type.lineage.erk"}
      }
    },
    "attribute": {
      "match": "^\\s*\\.([a-zA-Z_][a-zA-Z0-9_.]*)\\s*=",
      "captures": {
        "1": {"name": "variable.other.property.erk"}
      }
    },
    "relation": {
      "match": "\\b(depends_on|related_to|inherits_from|IN)\\b",
      "name": "keyword.operator.relation.erk"
    },
    "vector": {
      "match": "\\bV_[A-Za-z0-9_]+\\b",
      "name": "variable.other.vector.erk"
    },
    "string": {
      "match": "\"[^\"]*\"",
      "name": "string.quoted.double.erk"
    },
    "number": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.erk"
    },
    "keyword": {
      "match": "\\b(IF|THEN|ELSE|DO|AND|OR|NOT|WHEN|true|false|null)\\b",
      "name": "keyword.control.erk"
    }
  }
}
