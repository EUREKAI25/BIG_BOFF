Object:Entity:
  .name = V_Name
  .description = V_Description

Object:Entity:Agent:
  .name = V_Name
  .description = V_Description
  .temperature = V_Temperature
  .role = V_Role
  .model = V_Model
  .maxTokens = V_MaxTokens
  .permissions = V_Permissions

Object:Entity:Agent:AIAgent:
  .name = V_Name
  .description = V_Description
  .temperature = V_Temperature
  .role = V_Role
  .model = V_Model
  .maxTokens = V_MaxTokens
  .provider = V_Provider

Object:Entity:Agent:ArchitectAgent:
  .name = V_Name
  .description = V_Description
  .temperature = V_Temperature
  .role = V_Role
  .model = V_Model
  .specialization = V_Specialization

Object:Entity:Agent:OrchestratorAgent:
  .name = V_Name
  .description = V_Description
  .temperature = V_Temperature
  .role = V_Role
  .model = V_Model
  .maxConcurrent = V_MaxConcurrent
  .profile = V_Profile

Object:Entity:Agent:GeneratorAgent:
  .name = V_Name
  .description = V_Description
  .temperature = V_Temperature
  .role = V_Role
  .model = V_Model
  .outputFormat = V_OutputFormat
