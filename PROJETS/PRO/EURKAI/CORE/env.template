# ============================================================================
# BIG_BOFF — Template de configuration
# ============================================================================
# Copie ce fichier vers ~/.bigboff/secrets.env et renseigne tes clés.
# Ne JAMAIS commit ce fichier avec des vraies valeurs !
# ============================================================================

# === CONFIGURATION GÉNÉRALE ===
NODE_ENV=development
DEBUG=true
LOG_COSTS=true

# === AI PROVIDERS ===

# OpenAI — https://platform.openai.com/api-keys
# Modèles : GPT-4o, GPT-4, DALL-E-3, Whisper, TTS
OPENAI_API_KEY=sk-proj-...
OPENAI_ORG=
OPENAI_PROJECT=
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_LLM_MODEL=gpt-4o

# Anthropic — https://console.anthropic.com/
# Modèles : Claude Opus 4.6, Sonnet 4.5, Haiku 4.5
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://ai.google.dev/
# Modèles : Gemini Pro, Gemini Pro Vision
GEMINI_API_KEY=AIza...

# Replicate — https://replicate.com/account/api-tokens
# Modèles : Flux, SDXL, ControlNet, Stable Diffusion
REPLICATE_API_TOKEN=r8_...

# MiniMax — https://www.minimaxi.com/
# Modèles : MiniMax Video-01 (img2video)
MINIMAX_API_KEY=sk-api-...

# Runway — https://runwayml.com/
# Modèles : Gen-3 Alpha (text2video, img2video)
RUNWAY_API_KEY=key_...

# Fal.ai — https://fal.ai/dashboard/keys
# Modèles : Flux rapide, SDXL Turbo
FAL_KEY=...

# ElevenLabs — https://elevenlabs.io/
# Modèles : TTS multilangues
ELEVEN_LABS=sk_...

# === BASE DE DONNÉES ===
DATABASE_URL=postgresql://user@localhost:5432/dbname

# === AUTHENTIFICATION ===
JWT_SECRET=your-secret-key-min-32-chars

# === EMAILS & SMS ===
# Brevo (ex-Sendinblue) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=Your App Name

# === PAIEMENTS ===
# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === RÉSEAUX SOCIAUX ===
# Pinterest — https://developers.pinterest.com/apps/
PINTEREST_APP_ID=
PINTEREST_ACCESS_TOKEN=
PINTEREST_APP_STATUS=

# Meta (Facebook/Instagram) — https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=

# === GIT ===
# GitHub PAT — https://github.com/settings/tokens
GITHUB_PAT=ghp_...
GITHUB_OWNER=your-username
GITHUB_REPO=your-repo

# === URLS (environnements) ===
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
ADMIN_URL=http://localhost:5174
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PREPROD=https://preprod.example.com
FRONTEND_URL_PROD=https://example.com

# === STORAGE ===
STORAGE_PATH=./storage
SCRIPTS_PATH=./scripts
PYTHON_PATH=python

# === ALERTES ===
ALERT_EMAILS=admin@example.com

# === VECTOR DB (optionnel) ===
# Pinecone — https://app.pinecone.io/
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=us-west1-gcp

# Weaviate — https://console.weaviate.cloud/
# WEAVIATE_API_KEY=

# === CONFIGURATION MODÈLES (pour MODEL_EXECUTOR) ===
# Providers actifs par type de modèle
DEFAULT_PROVIDER=openai
MODEL_TEXT2TEXT_ACTIVE=openai
MODEL_TEXT2IMG_ACTIVE=replicate
MODEL_IMG2TEXT_ACTIVE=openai
MODEL_IMG2VIDEO_ACTIVE=minimax
MODEL_TEXT2AUDIO_ACTIVE=elevenlabs
