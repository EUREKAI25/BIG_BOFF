class Store:
    """Remote Store management"""
    
    @staticmethod
    def get(key: str) -> Any:
        """Get value from store"""
        resp = requests.get(f"{_config['base_url']}/store/get/{key}", timeout=_config['timeout'])
        return resp.json().get('value')
    
    @staticmethod
    def set(key: str, value: Any) -> None:
        """Set value in store"""
        requests.post(f"{_config['base_url']}/store/set", json={'key': key, 'value': value}, timeout=_config['timeout'])
    
    @staticmethod
    def keys() -> list[str]:
        """Get all keys"""
        resp = requests.get(f"{_config['base_url']}/store/keys", timeout=_config['timeout'])
        return resp.json().get('keys', [])
    
    @staticmethod
    def clear() -> None:
        """Clear all data"""
        requests.post(f"{_config['base_url']}/store/clear", timeout=_config['timeout'])
    
    @staticmethod
    def bulk_set(items: list[tuple[str, Any]]) -> None:
        """Set multiple values at once"""
        requests.post(
            f"{_config['base_url']}/store/bulk",
            json={'items': [{'key': k, 'value': v} for k, v in items]},
            timeout=_config['timeout']
        )

