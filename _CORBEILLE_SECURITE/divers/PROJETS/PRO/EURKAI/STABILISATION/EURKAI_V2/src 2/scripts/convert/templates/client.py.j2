import requests
from typing import Any, Optional, Union
from dataclasses import dataclass

# ============================================================================
# CONFIGURATION
# ============================================================================
_config = {
    'base_url': 'http://localhost:{{ port }}',
    'timeout': 30,
    'raise_on_error': True
}

def configure(base_url: str = None, timeout: int = None, raise_on_error: bool = None):
    """Configure the client connection settings"""
    if base_url is not None:
        _config['base_url'] = base_url.rstrip('/')
    if timeout is not None:
        _config['timeout'] = timeout
    if raise_on_error is not None:
        _config['raise_on_error'] = raise_on_error

@dataclass
class CallResult:
    """Result wrapper for API calls"""
    ok: bool
    result: Any = None
    error: str = None
    
    def unwrap(self) -> Any:
        """Return result or raise error"""
        if not self.ok:
            raise RuntimeError(self.error)
        return self.result

# ============================================================================
# LOW-LEVEL API
# ============================================================================
def _call(fn: str, args: list = None) -> CallResult:
    """Low-level function call"""
    args = args or []
    try:
        resp = requests.post(
            f"{_config['base_url']}/call",
            json={'fn': fn, 'args': args},
            timeout=_config['timeout']
        )
        data = resp.json()
        result = CallResult(ok=data.get('ok', False), result=data.get('result'), error=data.get('error'))
        if _config['raise_on_error'] and not result.ok:
            raise RuntimeError(f"API Error: {result.error}")
        return result
    except requests.RequestException as e:
        result = CallResult(ok=False, error=str(e))
        if _config['raise_on_error']:
            raise RuntimeError(f"Connection Error: {e}")
        return result

def batch_call(calls: list[tuple[str, list]]) -> list[CallResult]:
    """Execute multiple function calls in a single request"""
    try:
        resp = requests.post(
            f"{_config['base_url']}/batch",
            json={'calls': [{'fn': fn, 'args': args} for fn, args in calls]},
            timeout=_config['timeout']
        )
        data = resp.json()
        return [
            CallResult(ok=r.get('ok', False), result=r.get('result'), error=r.get('error'))
            for r in data.get('results', [])
        ]
    except requests.RequestException as e:
        return [CallResult(ok=False, error=str(e)) for _ in calls]

def health_check() -> bool:
    """Check if server is running"""
    try:
        resp = requests.get(f"{_config['base_url']}/health", timeout=5)
        return resp.json().get('status') == 'ok'
    except:
        return False

def list_functions() -> dict:
    """List available functions on server"""
    resp = requests.get(f"{_config['base_url']}/functions", timeout=5)
    return resp.json()

